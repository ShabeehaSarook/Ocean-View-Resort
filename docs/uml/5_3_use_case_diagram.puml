@startuml
title Ocean View Resort - UML Use Case Diagram

' A4 landscape-oriented layout tuning
left to right direction
scale max 1600 width
skinparam dpi 150
skinparam ranksep 60
skinparam nodesep 35
skinparam linetype ortho

actor Admin
actor Staff
actor Guest

rectangle "Ocean View Resort System" {
  usecase "Register Account" as UC_Register
  usecase "Login" as UC_Login
  usecase "Logout" as UC_Logout
  usecase "View Dashboard" as UC_Dashboard
  usecase "View Charts and Reports" as UC_Reports

  usecase "Manage Users" as UC_ManageUsers
  usecase "Manage Room Types" as UC_ManageRoomTypes
  usecase "Manage Rooms" as UC_ManageRooms

  usecase "Manage Reservations\n(All Guests)" as UC_ManageReservations
  usecase "Check-In / Check-Out" as UC_CheckInOut
  usecase "Manage Billing" as UC_ManageBilling

  usecase "Manage Own Reservations" as UC_OwnReservations
  usecase "View Own Bills" as UC_OwnBills

  usecase "Validate Business Rules" as UC_Validate
  usecase "Detect Reservation Overlap" as UC_Overlap
  usecase "Enforce Authentication\nand Role Access" as UC_AccessControl
}

' Admin interactions
Admin --> UC_Login
Admin --> UC_Logout
Admin --> UC_Dashboard
Admin --> UC_ManageUsers
Admin --> UC_ManageRoomTypes
Admin --> UC_ManageRooms
Admin --> UC_Reports

' Staff interactions
Staff --> UC_Login
Staff --> UC_Logout
Staff --> UC_Dashboard
Staff --> UC_ManageReservations
Staff --> UC_CheckInOut
Staff --> UC_ManageBilling
Staff --> UC_Reports

' Guest interactions
Guest --> UC_Register
Guest --> UC_Login
Guest --> UC_Logout
Guest --> UC_Dashboard
Guest --> UC_OwnReservations
Guest --> UC_OwnBills
Guest --> UC_Reports

' Shared behavior
UC_Dashboard .> UC_Reports : <<include>>
UC_ManageUsers .> UC_Validate : <<include>>
UC_ManageRoomTypes .> UC_Validate : <<include>>
UC_ManageRooms .> UC_Validate : <<include>>
UC_ManageReservations .> UC_Validate : <<include>>
UC_OwnReservations .> UC_Validate : <<include>>
UC_ManageBilling .> UC_Validate : <<include>>
UC_ManageReservations .> UC_Overlap : <<include>>
UC_OwnReservations .> UC_Overlap : <<include>>

' Security enforcement for protected use cases
UC_Dashboard .> UC_AccessControl : <<include>>
UC_ManageUsers .> UC_AccessControl : <<include>>
UC_ManageRoomTypes .> UC_AccessControl : <<include>>
UC_ManageRooms .> UC_AccessControl : <<include>>
UC_ManageReservations .> UC_AccessControl : <<include>>
UC_CheckInOut .> UC_AccessControl : <<include>>
UC_ManageBilling .> UC_AccessControl : <<include>>
UC_OwnReservations .> UC_AccessControl : <<include>>
UC_OwnBills .> UC_AccessControl : <<include>>
UC_Reports .> UC_AccessControl : <<include>>

@enduml
